  {
    "id": "cpp-0056",
    "prompt": "What must be true for `dynamic_cast<D*>(bptr)` to work?",
    "type": "single",
    "options": [
      {
        "id": "A",
        "text": "Base must be polymorphic (have at least one virtual function)",
        "isCorrect": true,
        "explanation": "Correct."
      },
      {
        "id": "B",
        "text": "D must have a virtual destructor",
        "isCorrect": false,
        "explanation": "Not required."
      },
      {
        "id": "C",
        "text": "bptr must be non-null",
        "isCorrect": false,
        "explanation": "Can be null; returns null."
      },
      {
        "id": "D",
        "text": "RTTI must be disabled",
        "isCorrect": false,
        "explanation": "No."
      },
      {
        "id": "E",
        "text": "It works for any types",
        "isCorrect": false,
        "explanation": "No."
      }
    ],
    "explanation": "See option explanations.",
    "tags": [
      "rtti",
      "dynamic_cast"
    ],
    "difficulty": "medium",
    "standard": "C++17"
  },
  {
    "id": "cpp-0057",
    "prompt": "What does `final` on a virtual function mean?",
    "type": "single",
    "options": [
      {
        "id": "A",
        "text": "It cannot be overloaded",
        "isCorrect": false,
        "explanation": "Overload still possible by signature, but not override."
      },
      {
        "id": "B",
        "text": "It cannot be overridden in derived classes",
        "isCorrect": true,
        "explanation": "Correct."
      },
      {
        "id": "C",
        "text": "It makes the function inline",
        "isCorrect": false,
        "explanation": "No."
      },
      {
        "id": "D",
        "text": "It forces dynamic dispatch",
        "isCorrect": false,
        "explanation": "Already virtual."
      },
      {
        "id": "E",
        "text": "It makes the class abstract",
        "isCorrect": false,
        "explanation": "No."
