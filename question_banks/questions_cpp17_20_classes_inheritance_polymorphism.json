  {
    "id": "cpp-0052",
    "prompt": "What does `override` do?",
    "type": "single",
    "options": [
      {
        "id": "A",
        "text": "Overloads a function",
        "isCorrect": false,
        "explanation": "No."
      },
      {
        "id": "B",
        "text": "Ensures at compile time the function overrides a virtual base function",
        "isCorrect": true,
        "explanation": "Correct."
      },
      {
        "id": "C",
        "text": "Makes the function virtual",
        "isCorrect": false,
        "explanation": "It implies, but must match base virtual."
      },
      {
        "id": "D",
        "text": "Prevents further overriding",
        "isCorrect": false,
        "explanation": "That's `final`."
      },
      {
        "id": "E",
        "text": "Changes calling convention",
        "isCorrect": false,
        "explanation": "No."
      }
    ],
    "explanation": "See option explanations.",
    "tags": [
      "polymorphism",
      "override",
      "c++11+"
    ],
    "difficulty": "easy",
    "standard": "C++17"
  },
